# AFS Configuration (copy to .env)
# See afs-config.json for the full settings reference.

OLLAMA_URL=http://localhost:11434
VISION_MODEL=llava:latest       # Any Ollama vision model (Step 1)
TEXT_MODEL=qwen3:8b              # Any Ollama reasoning model (Step 2)
VISION_TIMEOUT=180               # Seconds per vision call
TEXT_TIMEOUT=120                 # Seconds per reasoning call
SANITIZE_IMAGES=true             # CDR re-rendering for memes (photos auto-skipped)
CONVERT_WEBP=true                # Convert WebP to JPG during CDR
SKIP_CDR_PHOTOS=true             # Auto-detect camera photos and skip CDR
PHOTO_THRESHOLD_MP=4.0           # Megapixel threshold for photo detection
